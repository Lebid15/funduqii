# =========================================================================
# Funduqii — environment variables reference (Phase 1)
#
# This is a REFERENCE of all variables used by the project. Copy the backend
# section into backend/.env and the frontend section into frontend/.env.local.
# These are EXAMPLES ONLY. Never put real secrets in this file or commit real
# env files to Git.
# =========================================================================

# ------------------------- Backend (backend/.env) -------------------------
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://funduqii:funduqii@localhost:5432/funduqii
CORS_ALLOWED_ORIGINS=http://localhost:3000
LANGUAGE_CODE=en-us
TIME_ZONE=UTC
# Redis / Celery / Channels (Phase 1.5). Leave REDIS_URL empty for in-process
# dev fallbacks; set it (and start Redis) for real performance/realtime.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CHANNEL_LAYER_REDIS_URL=redis://localhost:6379/3
# Maps / messaging / integrations (Phase 1.6) — DISABLED placeholders, no secrets.
MAP_PROVIDER=disabled
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_BROWSER_KEY=
MAPBOX_ACCESS_TOKEN=
MESSAGING_PROVIDER=disabled
WHATSAPP_PROVIDER=disabled
WHATSAPP_API_BASE_URL=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
DEFAULT_COUNTRY_CODE=
PLATFORM_SUPPORT_WHATSAPP=
PLATFORM_SUPPORT_PHONE=

# --------------------- Frontend (frontend/.env.local) ---------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
