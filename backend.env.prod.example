# Funduqii backend PRODUCTION env (EXAMPLE) — copy to backend.env.prod (NOT committed).
# Fill real values on the server only. Never commit real secrets.

# Django (production settings module is selected in docker-compose.prod)
SECRET_KEY=generate-a-strong-random-secret-on-the-server
DEBUG=False
ALLOWED_HOSTS=api.funduqii.com,app.funduqii.com

# Database (internal Docker network host "db"; do NOT expose 5432 publicly)
DATABASE_URL=postgres://funduqii:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/funduqii

# CORS — only the real public origins
CORS_ALLOWED_ORIGINS=https://funduqii.com,https://app.funduqii.com

# Redis (internal host "redis"; do NOT expose 6379 publicly)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CHANNEL_LAYER_REDIS_URL=redis://redis:6379/3

# Security (production)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=2592000
DJANGO_LOG_LEVEL=INFO

# Locale
LANGUAGE_CODE=en-us
TIME_ZONE=UTC

# Maps / messaging / integrations (Phase 1.6). DISABLED by default.
# Enable and fill with REAL values on the server only (official APIs). Never in Git.
MAP_PROVIDER=disabled
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_BROWSER_KEY=
MAPBOX_ACCESS_TOKEN=
MESSAGING_PROVIDER=disabled
WHATSAPP_PROVIDER=disabled
WHATSAPP_API_BASE_URL=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
DEFAULT_COUNTRY_CODE=
PLATFORM_SUPPORT_WHATSAPP=
PLATFORM_SUPPORT_PHONE=
