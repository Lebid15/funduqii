# Funduqii backend environment (EXAMPLE) — copy to backend/.env and edit.
# Never commit a real .env file or real secrets.

# Django
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
LANGUAGE_CODE=en-us
TIME_ZONE=UTC

# Database — PostgreSQL is the canonical database.
DATABASE_URL=postgres://funduqii:funduqii@localhost:5432/funduqii

# CORS — allowed frontend origins (comma-separated).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Redis / Celery / Channels (Phase 1.5). Leave REDIS_URL empty to use safe
# in-process fallbacks in development. Real performance/realtime require Redis.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CHANNEL_LAYER_REDIS_URL=redis://localhost:6379/3

# Maps / messaging / integrations (Phase 1.6). All DISABLED by default.
# Placeholders only — put REAL keys/tokens on the server, never in Git.
MAP_PROVIDER=disabled
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_BROWSER_KEY=
MAPBOX_ACCESS_TOKEN=
MESSAGING_PROVIDER=disabled
WHATSAPP_PROVIDER=disabled
WHATSAPP_API_BASE_URL=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
DEFAULT_COUNTRY_CODE=
PLATFORM_SUPPORT_WHATSAPP=
PLATFORM_SUPPORT_PHONE=
