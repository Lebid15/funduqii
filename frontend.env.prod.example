# Funduqii frontend PRODUCTION env (EXAMPLE) — copy to frontend.env.prod (NOT committed).
# Only NEXT_PUBLIC_* values are exposed to the browser.
NEXT_PUBLIC_API_BASE_URL=https://api.funduqii.com/api

# Server-side API base used by the Backend-for-Frontend route handlers (session
# login/refresh + the /api/platform proxy). NOT exposed to the browser. Falls
# back to NEXT_PUBLIC_API_BASE_URL when unset; set it when the Next.js server
# reaches the API on a different (internal) host than the browser does.
API_INTERNAL_BASE_URL=https://api.funduqii.com/api
